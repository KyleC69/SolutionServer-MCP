  "server_details":
  {
    "icons":
    [
      {
        "url": "https://raw.githubusercontent.com/KyleC69.github.io/images/aifinger.png",
        "type": "image/png",
        "size": "256x256"
      }
    ],
    "runtime-hint": "dnx",
    "transport": "stdio",
